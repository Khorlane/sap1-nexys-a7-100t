# Normalize text files in the repository.
* text=auto

# Keep source/control files stable across Windows and other environments.
*.v text eol=lf
*.vh text eol=lf
*.sv text eol=lf
*.xdc text eol=lf
*.tcl text eol=lf
*.xpr text eol=lf
*.xml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.gitignore text eol=lf
*.gitattributes text eol=lf

# Binary/generated artifacts.
*.bit binary
*.bin binary
*.dcp binary
*.wdb binary
*.wcfg binary
*.pb binary
